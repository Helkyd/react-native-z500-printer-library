<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/keypad"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible">


        <TextView
            android:id="@+id/amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:letterSpacing="0.7"
            app:layout_constraintBottom_toTopOf="@+id/textPin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:id="@+id/textPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:letterSpacing="0.7"
            android:textAppearance="@style/TextAppearance.AppCompat.Display1"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/keyboard_view"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />




        <androidx.gridlayout.widget.GridLayout
            android:id="@+id/keyboard_view"
            android:layout_width="match_parent"
            android:layout_height="275dp"
            app:columnCount="3"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:rowCount="5">
            <!--row1-->
            <Button
                android:id="@+id/keyboard_1"
                android:layout_width="0dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="#FF3F3F3F"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:text="1"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <Button
                android:id="@+id/keyboard_2"
                android:layout_width="0dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="#FF3F3F3F"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:text="2"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <Button
                android:id="@+id/keyboard_3"
                android:layout_width="0dp"
                android:layout_marginBottom="3dp"
                android:background="#FF3F3F3F"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:text="3"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <!--row2-->
            <Button
                android:id="@+id/keyboard_4"
                android:layout_width="0dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="#FF3F3F3F"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:text="4"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <Button
                android:id="@+id/keyboard_5"
                android:layout_width="0dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="#FF3F3F3F"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:text="5"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <Button
                android:id="@+id/keyboard_6"
                android:layout_width="0dp"
                android:layout_marginBottom="3dp"
                android:background="#FF3F3F3F"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:text="6"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <!--row3-->
            <Button
                android:id="@+id/keyboard_7"
                android:layout_width="0dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="#FF3F3F3F"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:text="7"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <Button
                android:id="@+id/keyboard_8"
                android:layout_width="0dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="#FF3F3F3F"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:text="8"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <Button
                android:id="@+id/keyboard_9"
                android:layout_width="0dp"
                android:layout_marginBottom="3dp"
                android:background="#FF3F3F3F"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:text="9"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />


            <!--row4-->
            <Button
                android:layout_width="0dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="#FF3F3F3F"
                android:clickable="false"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <Button
                android:id="@+id/keyboard_0"
                android:layout_width="0dp"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="#FF3F3F3F"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:text="0"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <Button
                android:layout_width="0dp"
                android:layout_marginBottom="3dp"
                android:background="#FF3F3F3F"
                android:clickable="false"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <Button
                android:id="@+id/keyboard_cancel"
                android:layout_width="0dp"
                android:layout_marginEnd="3dp"
                android:background="#FFEB452D"
                android:text="Cancel"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <Button
                android:id="@+id/keyboard_clear"
                android:layout_width="0dp"
                android:layout_marginEnd="3dp"
                android:background="#FFFCB901"
                android:text="Clear"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />

            <Button
                android:id="@+id/keyboard_confirm"
                android:layout_width="0dp"
                android:background="#FF37BE31"
                android:text="Confirm"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1" />
        </androidx.gridlayout.widget.GridLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</RelativeLayout>